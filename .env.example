# ==========================================
# SMTP EMAIL SENDER CONFIGURATION
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail_username@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ==========================================
# RECIPIENT & LOGISTICS CONFIGURATION
# ==========================================
EMAIL_TO=your_destination_email@gmail.com
EMAIL_SUBJECT_PREFIX=DSA Problem

# ==========================================
# DATABASE STATE ROUTING
# ==========================================
DB_PATH=problems.db

# ==========================================
# SCHEDULING ENGINES
# OPTIONS: 'daily' | 'weekly'
# ==========================================
SCHEDULE_MODE=daily
DAILY_COUNT=5

WEEKLY_COUNT=20
WEEKLY_DAY=MON

# ==========================================
# TESTING / DRY RUN CONTROLS
# Set to 'true' to generate a local HTML file
# without sending real emails or changing DB state.
# ==========================================
DRY_RUN=false

# ==========================================
# GITHUB ACCESS (For Remote Reply Processing)
# ==========================================
GITHUB_REPO=username/repository-name
GITHUB_TOKEN=ghp_your_github_personal_access_token